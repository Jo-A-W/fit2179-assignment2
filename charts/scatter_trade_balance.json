{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "width": 600,
  "height": 400,
  "title": {
    "text": "Australia's Food Trade: Who Buys More Than They Sell Back?",
    "subtitle": "Each bubble = one trading partner. Hover to explore. Countries above the dashed line are ones Australia imports more from than it exports to.",
    "fontSize": 15,
    "subtitleFontSize": 11,
    "subtitleLineHeight": 15
  },
  "data": {
    "values": [
      {"country": "China",         "exports": 15800, "imports": 1324.8,  "trade_balance": 14475.2, "surplus": "AU Surplus", "region": "East Asia"},
      {"country": "Japan",         "exports": 5200,  "imports": 296.62,  "trade_balance": 4903.4,  "surplus": "AU Surplus", "region": "East Asia"},
      {"country": "South Korea",   "exports": 3100,  "imports": 315.94,  "trade_balance": 2784.1,  "surplus": "AU Surplus", "region": "East Asia"},
      {"country": "United States", "exports": 2800,  "imports": 1407.01, "trade_balance": 1393.0,  "surplus": "AU Surplus", "region": "Americas"},
      {"country": "Indonesia",     "exports": 2600,  "imports": 667.53,  "trade_balance": 1932.5,  "surplus": "AU Surplus", "region": "Southeast Asia"},
      {"country": "Vietnam",       "exports": 2100,  "imports": 360.53,  "trade_balance": 1739.5,  "surplus": "AU Surplus", "region": "Southeast Asia"},
      {"country": "Malaysia",      "exports": 1800,  "imports": 467.57,  "trade_balance": 1332.4,  "surplus": "AU Surplus", "region": "Southeast Asia"},
      {"country": "Thailand",      "exports": 1200,  "imports": 1276.5,  "trade_balance": -76.5,   "surplus": "AU Deficit", "region": "Southeast Asia"},
      {"country": "United Kingdom","exports": 900,   "imports": 744.26,  "trade_balance": 155.7,   "surplus": "AU Surplus", "region": "Europe"},
      {"country": "New Zealand",   "exports": 850,   "imports": 2080.41, "trade_balance": -1230.4, "surplus": "AU Deficit", "region": "Pacific"},
      {"country": "Singapore",     "exports": 650,   "imports": 963.46,  "trade_balance": -313.5,  "surplus": "AU Deficit", "region": "Southeast Asia"}
    ]
  },
  "params": [
    {
      "name": "region_select",
      "select": {"type": "point", "fields": ["region"]},
      "bind": "legend"
    }
  ],
  "layer": [
    {
      "mark": {"type": "point", "filled": true},
      "encoding": {
        "x": {
          "field": "exports",
          "type": "quantitative",
          "title": "AU Exports to Partner (AUD Millions)",
          "axis": {"format": ",.0f"},
          "scale": {"zero": true, "domainMax": 17000}
        },
        "y": {
          "field": "imports",
          "type": "quantitative",
          "title": "AU Imports from Partner (AUD Millions)",
          "axis": {"format": ",.0f"},
          "scale": {"zero": true, "domainMax": 2500}
        },
        "size": {
          "field": "exports",
          "type": "quantitative",
          "scale": {"range": [80, 2500]},
          "legend": null
        },
        "color": {
          "field": "region",
          "type": "nominal",
          "title": "Region",
          "scale": {
            "domain": ["East Asia", "Southeast Asia", "Americas", "Europe", "Pacific"],
            "range": ["#b35900", "#2980b9", "#27ae60", "#8e44ad", "#e67e22"]
          }
        },
        "shape": {
          "field": "surplus",
          "type": "nominal",
          "scale": {
            "domain": ["AU Surplus", "AU Deficit"],
            "range": ["circle", "triangle-up"]
          },
          "legend": {
            "title": "Trade Balance",
            "orient": "bottom-right"
          }
        },
        "opacity": {
          "condition": {"param": "region_select", "value": 0.9},
          "value": 0.15
        },
        "tooltip": [
          {"field": "country",       "type": "nominal",      "title": "Country"},
          {"field": "region",        "type": "nominal",      "title": "Region"},
          {"field": "exports",       "type": "quantitative", "title": "AU Exports (AUD M)", "format": "$,.0f"},
          {"field": "imports",       "type": "quantitative", "title": "AU Imports (AUD M)", "format": "$,.0f"},
          {"field": "trade_balance", "type": "quantitative", "title": "Trade Balance (AUD M)", "format": "$+,.0f"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 10,
        "fontWeight": "bold",
        "color": "#2c1a0e",
        "dx": 10,
        "align": "left"
      },
      "encoding": {
        "x": {"field": "exports", "type": "quantitative"},
        "y": {"field": "imports", "type": "quantitative"},
        "text": {"field": "country", "type": "nominal"},
        "opacity": {
          "condition": {"param": "region_select", "value": 1},
          "value": 0.1
        }
      }
    },
    {
      "data": {
        "values": [
          {"px": 0,     "py": 0},
          {"px": 17000, "py": 2500}
        ]
      },
      "mark": {
        "type": "line",
        "color": "#b35900",
        "strokeDash": [6, 4],
        "strokeWidth": 1,
        "opacity": 0.35
      },
      "encoding": {
        "x": {"field": "px", "type": "quantitative"},
        "y": {"field": "py", "type": "quantitative"}
      }
    },
    {
      "data": {
        "values": [
          {"px": 1200, "py": 2300, "label": "↑ AU imports more"},
          {"px": 5000, "py": 200,  "label": "↓ AU exports more"}
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 10,
        "fontStyle": "italic",
        "color": "#8a6a4a",
        "align": "left"
      },
      "encoding": {
        "x": {"field": "px", "type": "quantitative"},
        "y": {"field": "py", "type": "quantitative"},
        "text": {"field": "label", "type": "nominal"}
      }
    }
  ]
}