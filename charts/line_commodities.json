{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "width": 750,
  "height": 350,
  "title": {
    "text": "Key Australian Food Exports Over Time",
    "subtitle": "Value in AUD millions — click a category to highlight",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "data": {
    "url": "data/abares_key_commodities_exports.csv"
  },
  "transform": [
	{"filter": "datum.commodity != 'Total crops'"}
  ],
  "params": [
    {
      "name": "commodity_select",
      "select": {"type": "point", "fields": ["commodity"]},
      "bind": "legend"
    }
  ],
  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 2.5
  },
  "encoding": {
    "x": {
      "field": "financial_year",
      "type": "ordinal",
      "title": "Financial Year",
      "axis": {"labelAngle": -45}
    },
    "y": {
      "field": "value_aud_millions",
      "type": "quantitative",
      "title": "AUD Millions",
      "axis": {"format": ",.0f"}
    },
    "color": {
    "field": "commodity",
    "type": "nominal",
    "title": "Commodity",
    "scale": {
        "domain": ["Wheat", "Barley", "Canola", "Cotton", "Sugar", "Wine", "Fruit", "Tree nuts", "Vegetables"],
        "range": ["#e6194b", "#3cb44b", "#4363d8", "#f58231", "#911eb4", "#42d4f4", "#f032e6", "#bfef45", "#a9a9a9"]
    }
    },
    "opacity": {
      "condition": {"param": "commodity_select", "value": 1},
      "value": 0.15
    },
    "tooltip": [
      {"field": "financial_year", "type": "ordinal", "title": "Year"},
      {"field": "commodity", "type": "nominal", "title": "Commodity"},
      {"field": "value_aud_millions", "type": "quantitative", "title": "AUD Millions", "format": ",.0f"}
    ]
  }
}