{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "width": 400,
  "height": 300,
  "title": {
    "text": "Australia's Total Food Exports (2006–2025)",
    "subtitle": "Value in AUD millions — hover for details",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "data": {
    "url": "data/food_exports_total_by_year.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "area",
        "line": false,
        "color": "#b35900",
        "opacity": 0.08
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "value_aud_millions", "type": "quantitative"}
      }
    },
    {
      "mark": {
        "type": "line",
        "point": {"filled": true, "color": "#b35900", "size": 40},
        "color": "#b35900",
        "strokeWidth": 2.5
      },
      "encoding": {
        "x": {
          "field": "year", "type": "ordinal",
          "title": "Year",
          "axis": {"labelAngle": -45}
        },
        "y": {
          "field": "value_aud_millions", "type": "quantitative",
          "title": "AUD Millions",
          "axis": {"format": ",.0f"}
        },
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "value_aud_millions", "type": "quantitative", "title": "AUD Millions", "format": "$,.0f"}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"year": "2020", "label": "COVID-19\ndisruption", "y": 40430},
          {"year": "2025", "label": "Record\n$66.7B", "y": 66661}
        ]
      },
      "layer": [
        {
          "mark": {
            "type": "point",
            "shape": "circle",
            "size": 120,
            "filled": true,
            "color": "#2c1a0e",
            "opacity": 0.9
          },
          "encoding": {
            "x": {"field": "year", "type": "ordinal"},
            "y": {"field": "y", "type": "quantitative"}
          }
        },
        {
          "mark": {
            "type": "text",
            "fontSize": 10,
            "fontWeight": "bold",
            "color": "#2c1a0e",
            "align": "left",
            "dx": 8,
            "dy": -2
          },
          "encoding": {
            "x": {"field": "year", "type": "ordinal"},
            "y": {"field": "y", "type": "quantitative"},
            "text": {"field": "label", "type": "nominal"}
          }
        }
      ]
    }
  ]
}