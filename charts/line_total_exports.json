{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "width": 400,
  "height": 300,
  "title": {
    "text": "Australia's Total Food Exports (2006 to 2025)",
    "subtitle": "Value in AUD millions",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "data": {
    "url": "data/food_exports_total_by_year.csv"
  },
  "mark": {
    "type": "line",
    "point": {"filled": true, "color": "#b35900"},
    "color": "#b35900",
    "strokeWidth": 3
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Year",
      "axis": {"labelAngle": -45}
    },
    "y": {
      "field": "value_aud_millions",
      "type": "quantitative",
      "title": "AUD Millions",
      "axis": {"format": ",.0f"}
    },
    "tooltip": [
      {"field": "year", "type": "ordinal", "title": "Year"},
      {"field": "value_aud_millions", "type": "quantitative", "title": "AUD Millions", "format": ",.0f"}
    ]
  }
}