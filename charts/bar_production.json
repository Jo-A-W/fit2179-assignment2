{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "width": 400,
  "height": 400,
  "title": {
    "text": "Agricultural Production by Commodity (2024–25)",
    "subtitle": "Gross value in AUD millions — Source: ABARES",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "data": {
    "url": "data/abares_production_latest_year.csv"
  },
  "params": [
    {
      "name": "sort_order",
      "value": -1,
      "bind": {
        "input": "select",
        "options": [-1, 1],
        "labels": ["Highest first", "Lowest first"],
        "name": "Sort: "
      }
    }
  ],
  "transform": [
    {
      "calculate": "datum.value_aud_millions * sort_order",
      "as": "sort_val"
    }
  ],
  "layer": [
    {
      "mark": {"type": "bar"},
      "encoding": {
        "y": {
          "field": "commodity",
          "type": "nominal",
          "title": null,
          "sort": {"field": "sort_val", "order": "ascending"}
        },
        "x": {
          "field": "value_aud_millions",
          "type": "quantitative",
          "title": "AUD Millions",
          "axis": {"format": ",.0f"}
        },
        "color": {
          "field": "value_aud_millions",
          "type": "quantitative",
          "scale": {"scheme": "oranges"},
          "legend": null
        },
        "tooltip": [
          {"field": "commodity", "type": "nominal", "title": "Commodity"},
          {"field": "value_aud_millions", "type": "quantitative", "title": "AUD Millions", "format": "$,.0f"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 4,
        "fontSize": 10,
        "color": "#5a3e2b"
      },
      "encoding": {
        "y": {
          "field": "commodity",
          "type": "nominal",
          "sort": {"field": "sort_val", "order": "ascending"}
        },
        "x": {"field": "value_aud_millions", "type": "quantitative"},
        "text": {"field": "value_aud_millions", "type": "quantitative", "format": "$,.0f"}
      }
    }
  ]
}