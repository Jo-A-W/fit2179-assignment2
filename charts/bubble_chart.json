{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "padding": {"left": 10, "right": 10, "top": 10, "bottom": 10},
  "width": 750,
  "autosize": {"type": "fit", "contains": "padding"},  "height": 400,
  "title": {
    "text": "Top Australian Food Exports — Size vs Value (2024)",
    "subtitle": "Bubble size = export value — hover to explore",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  
  "data": {
    "url": "data/food_exports_top_commodities_2024.csv"
  },
  "transform": [
	{"filter": "datum.commodity_clean != 'Beef, f.c.f.'"}
  ],
  "mark": {
    "type": "circle",
    "opacity": 0.75,
    "stroke": "#b35900",
    "strokeWidth": 1
  },
  "encoding": {
    "x": {
      "field": "value_aud_millions",
      "type": "quantitative",
      "title": "Export Value (AUD Millions)",
      "axis": {"format": ",.0f"}
    },
    "y": {
      "field": "commodity_clean",
      "type": "nominal",
      "title": null,
      "sort": "-x"
    },
    "size": {
      "field": "value_aud_millions",
      "type": "quantitative",
      "title": "AUD Millions",
      "scale": {"range": [100, 3000]},
      "legend": null
    },
    "color": {
      "field": "value_aud_millions",
      "type": "quantitative",
      "scale": {"scheme": "oranges"},
      "legend": null
    },
    "tooltip": [
      {"field": "commodity_clean", "type": "nominal", "title": "Commodity"},
      {"field": "value_aud_millions", "type": "quantitative", "title": "AUD Millions", "format": ",.0f"}
    ]
  }
}
