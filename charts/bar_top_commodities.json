{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "width": 280,
  "height": 400,
  "title": {
    "text": "Top 15 Australian Food Exports (2024)",
    "subtitle": "Value in AUD millions — hover for details",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "data": {
    "url": "data/food_exports_top_commodities_2024.csv"
  },
  "params": [
    {
      "name": "sort_order_top",
      "value": -1,
      "bind": {
        "input": "select",
        "options": [-1, 1],
        "labels": ["Highest first", "Lowest first"],
        "name": "Sort: "
      }
    }
  ],
  "transform": [
    {
      "calculate": "datum.value_aud_millions * sort_order_top",
      "as": "sort_val"
    }
  ],
  "layer": [
    {
      "mark": {"type": "bar"},
      "encoding": {
        "y": {
          "field": "commodity_clean",
          "type": "nominal",
          "title": null,
          "sort": {"field": "sort_val", "order": "ascending"}
        },
        "x": {
          "field": "value_aud_millions",
          "type": "quantitative",
          "title": "AUD Millions",
          "axis": {"format": ",.0f"}
        },
        "color": {
          "field": "value_aud_millions",
          "type": "quantitative",
          "scale": {"scheme": "oranges"},
          "legend": null
        },
        "tooltip": [
          {"field": "commodity_clean", "type": "nominal", "title": "Commodity"},
          {"field": "value_aud_millions", "type": "quantitative", "title": "AUD Millions", "format": "$,.0f"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 4,
        "fontSize": 10,
        "color": "#5a3e2b"
      },
      "encoding": {
        "y": {
          "field": "commodity_clean",
          "type": "nominal",
          "sort": {"field": "sort_val", "order": "ascending"}
        },
        "x": {"field": "value_aud_millions", "type": "quantitative"},
        "text": {"field": "value_aud_millions", "type": "quantitative", "format": "$,.0f"}
      }
    }
  ]
}