{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "width": 750,
  "height": 350,
  "title": {
    "text": "Australian Food Exports by Category Over Time",
    "subtitle": "Value in AUD millions — hover to explore",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "data": {
    "url": "data/food_exports_by_category_year.csv"
  },
  "mark": {"type": "area"},
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Year",
      "axis": {"labelAngle": -45}
    },
    "y": {
      "field": "value_aud_millions",
      "type": "quantitative",
      "title": "AUD Millions",
      "stack": "zero",
      "axis": {"format": ",.0f"}
    },
    "color": {
      "field": "category",
      "type": "nominal",
      "title": "Category",
      "scale": {
        "domain": ["Meat & Livestock", "Grains & Cereals", "Beverages", "Fruit & Vegetables", "Dairy & Eggs", "Sugar & Confectionery", "Seafood", "Other Food"],
        "range": ["#c0392b", "#2980b9", "#f39c12", "#27ae60", "#8e44ad", "#e67e22", "#16a085", "#7f8c8d"]
      }
    },
    "tooltip": [
      {"field": "year", "type": "ordinal", "title": "Year"},
      {"field": "category", "type": "nominal", "title": "Category"},
      {"field": "value_aud_millions", "type": "quantitative", "title": "AUD Millions", "format": ",.0f"}
    ]
  }
}