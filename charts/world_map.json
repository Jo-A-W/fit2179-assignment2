{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "width": 900,
  "height": 450,
  "title": {
    "text": "Where Australia Sends Its Food (2024)",
    "subtitle": "Darker = higher export value in AUD millions",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "projection": {
    "type": "naturalEarth1",
    "clipExtent": [[0, 0], [900, 450]]
  },
  "layer": [
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "transform": [{"filter": "datum.id != 10"}],
      "mark": {"type": "geoshape", "fill": "#e8e8e8", "stroke": "white", "strokeWidth": 0.5}
    },
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "transform": [
        {
          "lookup": "id",
          "from": {
            "data": {"url": "data/food_exports_by_country_2024.csv"},
            "key": "id",
            "fields": ["country", "export_value_aud_millions"]
          }
        },
        {"filter": "datum.export_value_aud_millions != null"}
      ],
      "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 0.5},
      "encoding": {
        "color": {
          "field": "export_value_aud_millions",
          "type": "quantitative",
          "title": "AUD Millions",
          "scale": {"scheme": "oranges"}
        },
        "tooltip": [
          {"field": "country", "type": "nominal", "title": "Country"},
          {"field": "export_value_aud_millions", "type": "quantitative", "title": "AUD Millions", "format": ",.0f"}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"country": "China",     "value": "$15.8B", "latitude": 48,  "longitude": 105,  "name_length": 5},
          {"country": "Japan",     "value": "$5.2B",  "latitude": 42,  "longitude": 148,  "name_length": 5},
          {"country": "USA",       "value": "$2.8B",  "latitude": 53,  "longitude": -100, "name_length": 3},
          {"country": "Indonesia", "value": "$2.6B",  "latitude": 2,   "longitude": 135,  "name_length": 12}
        ]
      },
      "mark": {
        "type": "point",
        "shape": "square",
        "fill": "#faf6f0",
        "fillOpacity": 0.6,
        "stroke": "#d4b896",
        "strokeWidth": 1,
        "opacity": 1
      },
      "encoding": {
        "longitude": {"field": "longitude", "type": "quantitative"},
        "latitude":  {"field": "latitude",  "type": "quantitative"},
        "size": {
          "field": "name_length",
          "type": "quantitative",
          "scale": {"domain": [3, 12], "range": [800, 2000]},
          "legend": null
        }
      }
    },
    {
      "data": {
        "values": [
          {"country": "China",     "value": "$15.8B", "latitude": 48,  "longitude": 105},
          {"country": "Japan",     "value": "$5.2B",  "latitude": 42,  "longitude": 148},
          {"country": "USA",       "value": "$2.8B",  "latitude": 53,  "longitude": -100},
          {"country": "Indonesia", "value": "$2.6B",  "latitude": 2,   "longitude": 135}
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#2c1a0e",
        "align": "center",
        "dy": -6
      },
      "encoding": {
        "longitude": {"field": "longitude", "type": "quantitative"},
        "latitude":  {"field": "latitude",  "type": "quantitative"},
        "text":      {"field": "country",   "type": "nominal"}
      }
    },
    {
      "data": {
        "values": [
          {"country": "China",     "value": "$15.8B", "latitude": 48,  "longitude": 105},
          {"country": "Japan",     "value": "$5.2B",  "latitude": 42,  "longitude": 148},
          {"country": "USA",       "value": "$2.8B",  "latitude": 53,  "longitude": -100},
          {"country": "Indonesia", "value": "$2.6B",  "latitude": 2,   "longitude": 135}
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#b35900",
        "align": "center",
        "dy": 8
      },
      "encoding": {
        "longitude": {"field": "longitude", "type": "quantitative"},
        "latitude":  {"field": "latitude",  "type": "quantitative"},
        "text":      {"field": "value",     "type": "nominal"}
      }
    }
  ]
}