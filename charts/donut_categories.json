{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "title": {
    "text": "Food Exports by Category",
    "subtitle": "Use the slider to explore different years",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "width": 300,
  "height": 300,
  "data": {
    "url": "data/food_exports_by_category_year.csv"
  },
  "params": [
    {
      "name": "year_select",
      "value": 2024,
      "bind": {
        "input": "range",
        "min": 2006,
        "max": 2025,
        "step": 1,
        "name": "Select Year: "
      }
    }
  ],
  "transform": [
    {"filter": "datum.year == year_select"}
  ],
  "layer": [
    {
      "mark": {"type": "arc", "innerRadius": 85, "outerRadius": 140},
      "encoding": {
        "theta": {
          "field": "value_aud_millions",
          "type": "quantitative"
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "title": "Category",
          "scale": {
            "domain": ["Meat & Livestock", "Grains & Cereals", "Beverages", "Fruit & Vegetables", "Dairy & Eggs", "Sugar & Confectionery", "Seafood", "Other Food"],
            "range": ["#c0392b", "#2980b9", "#f39c12", "#27ae60", "#8e44ad", "#e67e22", "#16a085", "#7f8c8d"]
          }
        },
        "tooltip": [
          {"field": "category", "type": "nominal", "title": "Category"},
          {"field": "value_aud_millions", "type": "quantitative", "title": "AUD Millions", "format": "$,.0f"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#8a6a4a",
        "dy": -10,
        "font": "Inter, sans-serif"
      },
      "encoding": {
        "text": {"value": "Total"}
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "fontSize": 18,
        "fontWeight": "bold",
        "color": "#b35900",
        "dy": 10,
        "font": "Playfair Display, serif"
      },
      "transform": [
        {
          "aggregate": [{"op": "sum", "field": "value_aud_millions", "as": "total"}]
        },
        {
          "calculate": "'$' + format(datum.total / 1000, '.1f') + 'B'",
          "as": "total_label"
        }
      ],
      "encoding": {
        "text": {"field": "total_label", "type": "nominal"}
      }
    }
  ]
}